# name: test/sql/history.test
# description: vanguard fund_details / distributions / nav_history — schema + live invariants.
# group: [sql]

require-env VGI_TEST_WORKER

# CURRENT_DATE lives in icu, and the bare unittest binary does not autoload it (the
# DuckDB CLI and client libraries bundle icu, so the doc examples need no LOAD).
statement ok
LOAD icu;

statement ok
ATTACH 'vanguard' AS vg (TYPE vgi, LOCATION '${VGI_TEST_WORKER}');

statement ok
SET search_path='vg.main';

# --- Schema (bind-only, deterministic). ---

query T
SELECT column_type FROM (DESCRIBE SELECT * FROM vg.fund_details('VOO')) WHERE column_name = 'beta';
----
DOUBLE

query T
SELECT column_type FROM (DESCRIBE SELECT * FROM vg.nav_history('VOO')) WHERE column_name = 'nav';
----
DOUBLE

query T
SELECT column_type FROM (DESCRIBE SELECT * FROM vg.distributions('VOO')) WHERE column_name = 'record_date';
----
DATE

# --- Live invariants (hit Vanguard). ---

# fund_details is a single-row snapshot naming the primary benchmark.
query I
SELECT (count(*) = 1 AND max(primary_benchmark) IS NOT NULL AND max(expense_ratio_percent) >= 0)::INT FROM vg.fund_details('VOO');
----
1

# nav_history returns a NAV series with positive NAV for the default (1Y) window.
query I
SELECT (count(*) > 10 AND min(nav) > 0)::INT FROM vg.nav_history('VOO');
----
1

# The period argument selects a longer window (10Y → more points than a single month).
query I
SELECT (count(*) > 0)::INT FROM vg.nav_history('VOO', period := '10Y');
----
1

# A non-date value for the DATE argument is a bind error (SQL enforces the type).
statement error
SELECT * FROM vg.distributions('VOO', start_date := 'Jan 2026');
----

# VOO has a distribution history with non-negative per-share amounts.
query I
SELECT (count(*) > 0 AND min(per_share_amount) >= 0)::INT FROM vg.distributions('VOO');
----
1

# A bounded record-day window inside the published rolling window (~18 months) returns
# rows, and only rows inside it. Guards the class of bug that made the doc example
# empty: the source publishes a ROLLING window, so bounds must be derived from
# CURRENT_DATE — a hard-coded calendar year silently rots into an empty result.
query I
SELECT (count(*) > 0 AND min(record_date) >= (CURRENT_DATE - INTERVAL 1 YEAR)::DATE AND max(record_date) <= (CURRENT_DATE - INTERVAL 3 MONTH)::DATE)::INT FROM vg.distributions('VOO', start_date := (CURRENT_DATE - INTERVAL 1 YEAR)::DATE, end_date := (CURRENT_DATE - INTERVAL 3 MONTH)::DATE);
----
1
