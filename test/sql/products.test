# name: test/sql/products.test
# description: vanguard.products — base table: typed schema (network-free) + live catalog invariants.
# group: [sql]

require-env VGI_TEST_WORKER

statement ok
ATTACH 'vanguard' AS vg (TYPE vgi, LOCATION '${VGI_TEST_WORKER}');

statement ok
SET search_path='vg.main';

# --- Schema: DESCRIBE binds only (no network), so these are fully deterministic. ---
# `products` is a base TABLE — query it with no parentheses.

query T
SELECT column_type FROM (DESCRIBE SELECT * FROM vg.products) WHERE column_name = 'ticker';
----
VARCHAR

query T
SELECT column_type FROM (DESCRIBE SELECT * FROM vg.products) WHERE column_name = 'expense_ratio_percent';
----
DOUBLE

query T
SELECT column_type FROM (DESCRIBE SELECT * FROM vg.products) WHERE column_name = 'inception_date';
----
DATE

query T
SELECT column_type FROM (DESCRIBE SELECT * FROM vg.products) WHERE column_name = 'risk_code';
----
BIGINT

# --- Live invariants: these hit Vanguard. Assert shape, not exact (moving) values. ---

# The catalog has many ETFs.
query I
SELECT (count(*) > 50)::INT FROM vg.products;
----
1

# VOO (Vanguard S&P 500 ETF) is present with a non-negative expense ratio — via a WHERE.
query I
SELECT (count(*) = 1)::INT FROM vg.products WHERE ticker = 'VOO' AND expense_ratio_percent >= 0;
----
1

# Both equity and fixed-income ETFs are represented.
query I
SELECT (count(DISTINCT asset_class) >= 2)::INT FROM vg.products;
----
1
