# name: test/sql/holdings.test
# description: vanguard.holdings base table — fund_ticker partition (pushdown), current-only (no time travel).
# group: [sql]

require-env VGI_TEST_WORKER

statement ok
ATTACH 'vanguard' AS vg (TYPE vgi, LOCATION '${VGI_TEST_WORKER}');

statement ok
SET search_path='vg.main';

# --- Schema: DESCRIBE binds only (no network). `holdings` is a base TABLE. ---

query T
SELECT string_agg(column_name, ',') FROM (DESCRIBE SELECT * FROM vg.holdings WHERE fund_ticker = 'VOO');
----
fund_ticker,holding_rank,as_of_date,name,ticker,isin,cusip,sedol,weight_percent,market_value,shares_held,notional_value,sec_type,coupon_percent,maturity,face_amount

query T
SELECT column_type FROM (DESCRIBE SELECT * FROM vg.holdings WHERE fund_ticker = 'VOO') WHERE column_name = 'as_of_date';
----
DATE

# --- Live invariants (hit Vanguard). ---

# Partition pushdown: WHERE fund_ticker = 'VOO' fetches that fund's holdings, weight-descending.
query I
SELECT (count(*) > 100 AND max(weight_percent) > 0 AND bool_and(fund_ticker = 'VOO'))::INT
FROM vg.holdings WHERE fund_ticker = 'VOO';
----
1

# Every row of a fund carries the same reported as-of date.
query I
SELECT (count(DISTINCT as_of_date) = 1 AND max(as_of_date) IS NOT NULL)::INT
FROM vg.holdings WHERE fund_ticker = 'VOO';
----
1

# Multiple partitions at once: fund_ticker IN (...) fans out to two funds.
query I
SELECT (count(DISTINCT fund_ticker) = 2)::INT FROM vg.holdings WHERE fund_ticker IN ('VOO', 'VTI');
----
1

# An unfiltered scan streams EVERY fund's holdings (one partition per fund). LIMIT short-circuits
# the stream after the first partition, so this stays cheap (no full fan-out).
query I
SELECT (count(*) >= 1)::INT FROM (SELECT * FROM vg.holdings LIMIT 5);
----
1

# The backing scan function also works directly (pushdown).
query I
SELECT (count(*) > 100)::INT FROM vg.holdings_scan() WHERE fund_ticker = 'VOO';
----
1
